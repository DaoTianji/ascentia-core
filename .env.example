# =============================================================================
# ascentia-core 环境变量模板（复制为 .env 后填写；勿提交 .env 到 Git）
# 合并白名单见 internal/configenv/apply.go（Redis L2 / sys_core_settings 仅覆盖表中键）
# =============================================================================

# -----------------------------------------------------------------------------
# 大模型（OpenAI 兼容 Chat Completions：/v1/chat/completions）
# -----------------------------------------------------------------------------
# 变量名沿用 ANTHROPIC_* 历史前缀，实际指向任意 OpenAI 兼容网关即可。
# 必填：网关 Base URL（无则进程无法创建 LLM 客户端）
# ANTHROPIC_BASE_URL=https://api.openai.com

# 鉴权二选一：Bearer Token（多数代理填此项）或 API Key 变量（部分部署习惯）
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_API_KEY=

# 模型 ID：不配则依次尝试 ANTHROPIC_DEFAULT_SONNET_MODEL、ANTHROPIC_DEFAULT_HAIKU_MODEL
# ANTHROPIC_MODEL=gpt-4o-mini
# ANTHROPIC_DEFAULT_SONNET_MODEL=
# ANTHROPIC_DEFAULT_HAIKU_MODEL=

# 单次 HTTP 客户端超时（毫秒）。不配默认 300000（5 分钟）；流式长推理可适当加大
# API_TIMEOUT_MS=300000

# -----------------------------------------------------------------------------
# 每连接模型覆盖（任意调用方）
# -----------------------------------------------------------------------------
# 调用方可在 WS 握手查询串带 ?model=，覆盖当次请求的 OpenAI-compatible model id，
# 不修改本文件里的 ANTHROPIC_MODEL。未带 model 时使用上面环境默认模型。

# -----------------------------------------------------------------------------
# HTTP / WebSocket
# -----------------------------------------------------------------------------
# PORT=8080
# WS_PATH=/ws

# -----------------------------------------------------------------------------
# WebSocket 安全（生产务必显式配置；见 docs/zh-CN/WS_SECURITY.md 或 docs/en/WS_SECURITY.md）
# -----------------------------------------------------------------------------
# WS_ALLOWED_ORIGINS=* | https://app.example.com,http://localhost:8080
#   浏览器 Origin 白名单；* 表示允许任意 Origin（不推荐生产）
# WS_STRICT_ORIGIN=1
#   与 WS_ALLOWED_ORIGINS 配合：未列 Origin 且带 Origin 头的请求将被拒绝
# WS_AUTH_MODE=none | bearer | jwt
#   none：不校验（仅可信网络）；bearer：Authorization: Bearer <WS_BEARER_TOKEN>
#   jwt：HS256 JWT；user_id 以 token 内顶层数值字段 ID 为准（与常见 admin 模板兼容；异构 IdP 请在网关映射）
# WS_BEARER_TOKEN=
# WS_JWT_HS256_SECRET=
#   与签发该 JWT 的 HS256 密钥一致（仅 WS_AUTH_MODE=jwt）
# GVA_JWT_SIGNING_KEY=
#   已弃用别名，等同于 WS_JWT_HS256_SECRET（遗留部署兼容）
# WS_ALLOW_QUERY_BEARER=1
#   允许 ?bearer_token=（浏览器无法设 WS Header 时的退路，慎用）
# WS_ALLOW_QUERY_JWT=1
#   允许 ?access_token= JWT（URL 可能进日志，仅配合 HTTPS）
# WS_MAX_MESSAGES_PER_MINUTE=60
#   每客户端 IP 每分钟最大 user_message 数；0 或不配表示不限

# -----------------------------------------------------------------------------
# 工具
# -----------------------------------------------------------------------------
# DISABLE_SPAWN_PET=1
#   关闭 SpawnPet 工具（仍保留读/写记忆工具）

# -----------------------------------------------------------------------------
# 工具循环
# -----------------------------------------------------------------------------
# MAX_TURNS=8
# MAX_TOOL_FAILURE_STREAK=3

# -----------------------------------------------------------------------------
# 默认租户（无 WS user_id/agent_id 覆盖时；Dream 定时任务也使用该 scope）
# -----------------------------------------------------------------------------
# DEFAULT_USER_ID=default-user
# DEFAULT_AGENT_ID=overseer

# -----------------------------------------------------------------------------
# 可选基础设施
# -----------------------------------------------------------------------------
# NATS_URL=nats://127.0.0.1:4222
# REDIS_URL=redis://127.0.0.1:6379/0
# 或拆分：REDIS_ADDR=127.0.0.1:6379  REDIS_PASSWORD=  REDIS_DB=0
# DATABASE_URL=postgres://user:pass@localhost:5432/ascentia?sslmode=disable

# STM（会话消息条数 / TTL，仅在使用 REDIS_ADDR 路径时读取；REDIS_URL 路径同样生效部分）
# SESSION_MAX_MESSAGES=60
# SESSION_TTL_SECONDS=86400

# -----------------------------------------------------------------------------
# 控制面配置注入（进阶）
# -----------------------------------------------------------------------------
# CORE_CONFIG_FROM_PG=1
#   启动时从「当前 DATABASE_URL 所连库」的 sys_core_settings 合并白名单键（仅联调/共库）
# CORE_CONFIG_BUS=1
#   需 REDIS_URL + NATS_URL：启动拉 Redis 快照，并订阅 NATS 热更新
# CORE_CONFIG_HOT_LLM=0
#   设为 0/false/off 时，NATS 热更新后不重建 LLM 客户端

# -----------------------------------------------------------------------------
# 记忆：回合后自动抽取 → PG LTM
# -----------------------------------------------------------------------------
# MEMORY_AUTO_EXTRACT=0
#   设为 0/false/off 关闭；开启时每轮 WS 成功结束后异步调一次小模型写记忆
# MEMORY_EXTRACT_MAX_TOKENS=512

# -----------------------------------------------------------------------------
# 记忆：Dream 定时整理（需 DATABASE_URL + 未 MEMORY_DREAM=0）
# -----------------------------------------------------------------------------
# MEMORY_DREAM=0
# MEMORY_DREAM_INTERVAL_MINUTES=30
#   不配默认 30；设为 0 关闭定时器
# MEMORY_DREAM_MAX_TOKENS=3072

# -----------------------------------------------------------------------------
# 上下文压缩与工具结果截断
# -----------------------------------------------------------------------------
# CONTEXT_TOKEN_BUDGET=48000
#   设为 0 / off / false 关闭压缩
# CONTEXT_COMPACT_MIN_TAIL=8
# TOOL_RESULT_MAX_RUNES=20000
#   设为 0 / off / false 关闭截断

# -----------------------------------------------------------------------------
# 默认人设 / 运行提示（无 WS persona 时使用）
# -----------------------------------------------------------------------------
# AGENT_PERSONA=
# RUNTIME_HINT=

# -----------------------------------------------------------------------------
# 下列键可被 L2 合并进进程，但 ascentia-core 主程序不读取（可留给本机其他 CLI）
# -----------------------------------------------------------------------------
# CLAUDE_CODE_DISABLE_THINKING=1
# CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
# DISABLE_TELEMETRY=1
