# ascentia-core 线上环境示例（复制为服务器上的 .env，由 Docker env_file 或进程读取）
# 勿提交含真实密钥的 .env 到 Git。
#
# 与「管理端改名」无关：Core 不读取 Go module 路径；只需基础设施与模型网关一致。
#
# 通常保持默认即可的项（不配则用代码默认值）：
# - PORT=8080、WS_PATH=/ws
# - MAX_TURNS、SESSION_*、CONTEXT_*、TOOL_RESULT_* 等调优项
#
# 上线必须填写（或按你架构指向内网地址）：
# - ANTHROPIC_BASE_URL + 鉴权 + ANTHROPIC_MODEL
# - REDIS_URL 和/或 DATABASE_URL、NATS_URL（若功能需要）

# ----- 大模型（OpenAI 兼容 /v1/chat/completions）-----
ANTHROPIC_BASE_URL=https://CHANGEME_GATEWAY.example/v1
ANTHROPIC_AUTH_TOKEN=CHANGEME_TOKEN
# ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=CHANGEME_MODEL_ID
API_TIMEOUT_MS=300000

# ----- HTTP / WebSocket（容器内端口；宿主机映射在 compose 里写 31902:8080 等）-----
PORT=8080
WS_PATH=/ws

MAX_TURNS=8

# ----- 基础设施（示例占位；Docker 内访问宿主机 MySQL 需用 host 网络或宿主机 IP）-----
NATS_URL=nats://CHANGEME_NATS_HOST:4222
REDIS_URL=redis://:CHANGEME_REDIS_PASS@CHANGEME_REDIS_HOST:6379/0
DATABASE_URL=postgres://CHANGEME_USER:CHANGEME_PASS@CHANGEME_PG_HOST:5432/CHANGEME_DB?sslmode=disable

# ----- 可选：与控制面共库/热更新（按需在服务器打开）-----
# CORE_CONFIG_FROM_PG=1
# CORE_CONFIG_BUS=1
# CORE_CONFIG_HOT_LLM=0

# MEMORY_DREAM=0
# MEMORY_DREAM_INTERVAL_MINUTES=30
# MEMORY_DREAM_MAX_TOKENS=3072

# DEFAULT_USER_ID=default-user
# DEFAULT_AGENT_ID=overseer

# AGENT_PERSONA=
# RUNTIME_HINT=

CLAUDE_CODE_DISABLE_THINKING=1
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
DISABLE_TELEMETRY=1
